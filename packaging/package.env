# Safelibs port metadata for libvips.
#
# The actual Debian package metadata for this port lives in safe/debian/.
# scripts/build-debs.sh runs dpkg-buildpackage there; the DEB_* fields
# below are template-required scaffolding for tools that haven't been
# updated yet, and are not consumed by this port's build.

SAFELIBS_LIBRARY="libvips"

DEB_PACKAGE="safelibs-port-libvips"
DEB_VERSION="0.0.0"
DEB_ARCHITECTURE="auto"
DEB_MAINTAINER="SafeLibs <ci@safelibs.org>"
DEB_SECTION="libs"
DEB_PRIORITY="optional"
DEB_DESCRIPTION="Safe libvips port (built via safe/debian)."
DEB_INSTALL_PREFIX="/usr/lib/safelibs/safelibs-port-libvips"
DEB_DEPENDS=""
